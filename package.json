{
  "name": "morphing-scroll",
  "version": "2.10.5",
  "description": "React library for custom object scrolling and scrollbar styling",
  "author": "Georg Schilin",
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && rollup -c rollup.config.mjs && node scripts/prepare-dist.mjs",
    "build:dev": "npm run typecheck && MORPHING_SCROLL_BUILD=development rollup -c rollup.config.mjs && node scripts/prepare-dist.mjs",
    "package-prepare": "npm run build && node scripts/prepare-publish.mjs",
    "publish": "cd publish && npm publish",
    "lint": "eslint src"
  },
  "keywords": [
    "react",
    "scroll"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^24.0.7",
    "@types/react": "^19.1.10",
    "csstype": "^3.1.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "rollup": "^4.21.3",
    "rollup-plugin-delete": "^2.1.0",
    "tslib": "^2.7.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.18.0"
  },
  "peerDependencies": {
    "react": ">=16.8 <20"
  },
  "dependencies": {
    "keytask-core": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voodoofugu/morphing-scroll.git"
  }
}
